# Supabase Configuration
# Copy this file to .env.local and fill in your credentials
# Get these values from: https://app.supabase.com → Your Project → Settings → API

# Your Supabase project URL (safe to share, used by the client)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/public key (safe to share, used by the client)
# This key only allows access controlled by Row Level Security (RLS) policies
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only Supabase configuration for Netlify Functions
# Add these in Netlify Site settings -> Environment variables. Do not expose
# the service role key in frontend code.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# WhatsApp Cloud API configuration for automatic installment notifications
# Template body:
# Hi {{1}}, your installment payment of {{2}} (Installment #{{3}}) has been recorded on {{4}}. Receipt: {{5}}. Late fee: {{6}}. Thank You, I J Reddy.
WHATSAPP_ACCESS_TOKEN=your-permanent-token-here
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id-here
WHATSAPP_INSTALLMENT_TEMPLATE_NAME=installment_payment_recorded
WHATSAPP_TEMPLATE_LANGUAGE=en
WHATSAPP_GRAPH_API_VERSION=v20.0
WHATSAPP_DEFAULT_COUNTRY_CODE=91
